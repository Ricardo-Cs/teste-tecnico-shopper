generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ride {
  id          Int      @id @default(autoincrement())
  origin      String
  date        DateTime
  destination String
  distance    Int
  duration    String
  value       Int
  driver      driver   @relation(fields: [driver_id], references: [id])
  driver_id   Int
}

model driver {
  id              Int    @id @default(autoincrement())
  name            String
  description     String
  car_model       String
  rating          Int
  fee_per_km      Int
  min_distance_km Int
  ride            ride[]
}
